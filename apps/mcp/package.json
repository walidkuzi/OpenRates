{
  "name": "@openrates/mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "openrates-mcp": "./dist/cli.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts --stdio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@openrates/cache": "workspace:*",
    "@openrates/core": "workspace:*",
    "@openrates/currency-metadata": "workspace:*",
    "@openrates/observability": "workspace:*",
    "@openrates/provider-frankfurter": "workspace:*",
    "@openrates/provider-interface": "workspace:*",
    "@openrates/router": "workspace:*",
    "@openrates/schemas": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
